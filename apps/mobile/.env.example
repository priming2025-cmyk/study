SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 웹 PKCE / OAuth: Supabase Dashboard → Authentication → URL configuration
# - Site URL: 예) flutter run -d chrome 시 나오는 origin (http://localhost:xxxxx)
# - Redirect URLs: 로컬·스테이징·프로덕션 origin을 모두 등록

# 영상 스터디방(WebRTC): true 면 방 만들기/참여가 열림. 기본 테스트는 false 권장(무료는 집중 세션 출석 UX).
PREMIUM_VIDEO_ENABLED=false

# WebRTC TURN (스터디방이 P2P로 안 붙을 때만 필요). 비우면 STUN만 사용합니다.
# 배포 시: https 환경 + 올바른 MIME(wasm) 확인. COOP/COEP 헤더는 일부 OAuth 팝업과 충돌할 수 있어요.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

